# LocalRtdatahub — local development configuration
# Copy to `.env` and adjust to taste.
#
# Both upstream-style dotted keys (`MOBILITYDB.DB`) and underscore-style
# (`MOBILITYDB_DB`) are accepted, so an upstream `.env` can be reused as-is.

# PostgreSQL — either set DATABASE_URL or the per-component vars below.
# Defaults match the README setup commands.
DATABASE_URL=postgresql://rtdatahub:rtdatahub@localhost:5432/rtdatahub_local
# MOBILITYDB.DB=rtdatahub_local
# MOBILITYDB.USER=rtdatahub
# MOBILITYDB.PASSWORD=rtdatahub
# MOBILITYDB.HOST=127.0.0.1
# MOBILITYDB.PORT=5432

# Flask listen address (loopback by default — change to 0.0.0.0 to expose).
LISTEN_HOST=127.0.0.1
LISTEN_PORT=8090
DEFAULT_HOURS=1

# STIB Open Data Portal — required only by src/etl/ingestion/stib/.
STIB_ODP_KEY=

# Ingestion batch size (rows per execute_values call).
INGEST_BATCH_SIZE=5000
